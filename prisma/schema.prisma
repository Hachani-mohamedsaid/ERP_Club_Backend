generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN_CLUB
  SUPER_ADMIN
}

model User {
  id            String        @id @default(uuid())
  email         String        @unique
  passwordHash  String
  fullName      String
  phone         String
  role          UserRole      @default(ADMIN_CLUB)
  acceptTerms   Boolean       @default(false)
  acceptPrivacy Boolean       @default(false)
  isActive      Boolean       @default(true)
  organization  Organization?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Organization {
  id             String              @id @default(uuid())
  clubName       String
  country        String
  league         String
  logoUrl        String?
  invitationCode String?
  ownerId        String              @unique
  owner          User                @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  dashboardStats ClubDashboardStats?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
}

model ClubDashboardStats {
  id               String       @id @default(uuid())
  organizationId   String       @unique
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  playersCount     Int          @default(0)
  staffCount       Int          @default(1)
  budgetRemaining  Int          @default(500000)
  payrollTotal     Int          @default(0)
  injuredCount     Int          @default(0)
  contractsToRenew Int          @default(0)
  budgetUsedPct    Int          @default(0)
  budgetChart      Json
  alerts           Json
  aiSummary        Json
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model InvitationCode {
  id        String   @id @default(uuid())
  code      String   @unique
  isActive  Boolean  @default(true)
  maxUses   Int?
  usedCount Int      @default(0)
  createdAt DateTime @default(now())
}
